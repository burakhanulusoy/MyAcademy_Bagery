                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px"
              },
              "spacing": {
                      "container-max": "1200px",
                      "margin-mobile": "16px",
                      "gutter": "24px",
                      "base": "8px",
                      "section-gap": "80px"
              },
              "fontFamily": {
                      "headline-lg-mobile": [
                              "Literata"
                      ],
                      "body-md": [
                              "Plus Jakarta Sans"
                      ],
                      "label-lg": [
                              "Plus Jakarta Sans"
                      ],
                      "display": [
                              "Literata"
                      ],
                      "body-lg": [
                              "Plus Jakarta Sans"
                      ],
                      "headline-lg": [
                              "Literata"
                      ],
                      "form-input": [
                              "Plus Jakarta Sans"
                      ]
              },
              "fontSize": {
                      "headline-lg-mobile": [
                              "28px",
                              {
                                      "lineHeight": "36px",
                                      "fontWeight": "600"
                              }
                      ],
