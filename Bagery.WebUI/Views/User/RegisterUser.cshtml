    <style>
        /* Ambient Coffee Shadows */
        .shadow-bakery {
            box-shadow: 0 20px 40px rgba(75, 54, 33, 0.15);
        }
        .shadow-bakery-inner {
            box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.15), 0 4px 10px rgba(75, 54, 33, 0.12);
        }
    </style>
</head>
<body class="text-on-surface min-h-screen flex flex-col lg:flex-row antialiased bg-surface">
    <!-- Left Side: Full Height Image -->
    <div class="hidden lg:block lg:w-1/2 relative min-h-screen">
        <img alt="Artisanal Bakery Setting" class="absolute inset-0 w-full h-full object-cover" data-alt="A warm, high-end lifestyle photograph of freshly baked artisanal croissants and a steaming cup of coffee in a rustic ceramic mug, resting on a textured light-wood bakery table." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQUVIDkpq9J_c2ZTalj7HXVIz8Y3U3rdO-Mk9n_Z5gB9sJP70K8Oe-VQVF7Gzc4pAfBoEqbV1XdbsItB2JzNF2ujx2eENWYUBYQWYgC1yP1K562SI42V69XENGZguVq8KRWBfU4rOoStXCaX4c8aKITl9wL1_nEdlUYjNGMDDHcIelwRzAt5VHW64X_7tBSo3kVeNuK0xxazYr6u2m5Hv-2a4BuCnUzFSG5gLqna97EgyMygofePARJxvf1i-Ta9OTZSW95ONvxuem" />
        <!-- Overlays for legibility and mood -->
        <div class="absolute inset-0 bg-primary/20 mix-blend-multiply"></div>
    </div>
    <!-- Right Side: Registration Form Container -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 md:p-16 lg:p-20 bg-surface">
        <main class="w-full max-w-[520px]">
            <header class="mb-8 text-center">
                <h1 class="font-display text-display text-primary tracking-tight mb-2">BAKERY</h1>
                <p class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-on-surface-variant">Aramıza Katılın</p>
                <p class="font-body-md text-body-md text-outline mt-2">Taze kahve ve artizan lezzetler için hesabınızı oluşturun.</p>
            </header>
            <form method="post" class="flex flex-col gap-5">

                <!-- Hata Bildirim Kutusu -->
                <div asp-validation-summary="All" class="p-4 rounded-xl bg-error-container text-on-error-container border border-error/30 shadow-sm mb-6">
                    <div class="flex items-center gap-2 mb-3 pb-2 font-bold text-error border-b border-error/20">
                        <span class="material-symbols-outlined text-[22px]">error</span>
                        <span class="text-[15px]">Lütfen aşağıdaki hataları düzeltin:</span>
                    </div>
                </div>
                

                <!-- Ad Soyad & Kullanıcı Adı -->
                <div class="flex flex-col sm:flex-row gap-5">
                    <div class="flex-1 flex flex-col gap-1.5">
                        <label class="text-[14px] font-semibold text-on-surface-variant ml-1">Ad Soyad</label>
                        <input asp-for="FullName" class="w-full rounded-lg bg-surface-container/80 border-2 border-transparent px-4 py-3 focus:outline-none focus:border-primary focus:bg-surface-container-lowest transition-all shadow-sm" placeholder="Örn. Ayşe Yılmaz" />
                    </div>
                    <div class="flex-1 flex flex-col gap-1.5">
                        <label class="text-[14px] font-semibold text-on-surface-variant ml-1">Kullanıcı Adı</label>
                        <input asp-for="UserName" class="w-full rounded-lg bg-surface-container/80 border-2 border-transparent px-4 py-3 focus:outline-none focus:border-primary focus:bg-surface-container-lowest transition-all shadow-sm" placeholder="ayseyilmaz" />
                    </div>
                </div>

                <!-- Email -->
                <div class="flex flex-col gap-1.5">
                    <label class="text-[14px] font-semibold text-on-surface-variant ml-1">E-posta</label>
                    <input asp-for="Email" class="w-full rounded-lg bg-surface-container/80 border-2 border-transparent px-4 py-3 focus:outline-none focus:border-primary focus:bg-surface-container-lowest transition-all shadow-sm" placeholder="merhaba@ornek.com" />
                </div>

                <!-- Telefon -->
                <div class="flex flex-col gap-1.5">
                    <label class="text-[14px] font-semibold text-on-surface-variant ml-1">Telefon Numarası</label>
                    <input asp-for="PhoneNumber" class="w-full rounded-lg bg-surface-container/80 border-2 border-transparent px-4 py-3 focus:outline-none focus:border-primary focus:bg-surface-container-lowest transition-all shadow-sm" placeholder="5xx xxx xxxx" />
                </div>

                <!-- Şifre -->
                <div class="flex flex-col gap-1.5">
                    <label class="text-[14px] font-semibold text-on-surface-variant ml-1">Şifre</label>
                    <input required asp-for="Password" type="password" class="w-full rounded-lg bg-surface-container/80 border-2 border-transparent px-4 py-3 focus:outline-none focus:border-primary focus:bg-surface-container-lowest transition-all shadow-sm" placeholder="••••••••" />
                </div>

                <!-- Şifre Tekrarı -->
                <div class="flex flex-col gap-1.5">
                    <label class="text-[14px] font-semibold text-on-surface-variant ml-1">Şifre Tekrarı</label>
                    <input required asp-for="ConfirmPassword" type="password" class="w-full rounded-lg bg-surface-container/80 border-2 border-transparent px-4 py-3 focus:outline-none focus:border-primary focus:bg-surface-container-lowest transition-all shadow-sm" placeholder="••••••••" />
                </div>

                <!-- Koşullar -->
                <div class="flex flex-col gap-1">
                    <div class="flex items-start gap-3 mt-2">
                        <input id="terms" type="checkbox" required class="mt-1 w-5 h-5 rounded border-outline text-primary focus:ring-primary bg-surface-container/80 cursor-pointer" />
                        <label for="terms" class="text-sm text-on-surface-variant cursor-pointer">
                            <span class="text-secondary font-medium hover:underline decoration-dashed">Kullanım Koşulları</span>'nı ve
                            <span class="text-secondary font-medium hover:underline decoration-dashed">Gizlilik Politikası</span>'nı okudum.
                        </label>
                    </div>
                </div>

                <!-- Kayıt Butonu -->
                <button class="w-full py-4 rounded-xl bg-primary text-on-primary font-bold text-center mt-4 shadow-bakery hover:bg-opacity-90 transition-all active:scale-[0.98] flex items-center justify-center gap-2 group">
                    Kayıt Ol
                    <span class="material-symbols-outlined text-[20px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </button>

                <!-- Sosyal Login Separator -->
                <div class="relative mt-2">
                    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-outline-variant/60"></div></div>
                    <div class="relative flex justify-center text-xs uppercase tracking-widest"><span class="px-3 bg-surface text-outline font-bold">veya</span></div>
                </div>

                <!-- Sosyal Butonlar -->
                <div class="grid grid-cols-2 gap-4">
                    <a  class="flex items-center justify-center gap-2 rounded-xl border border-outline-variant/60 bg-white px-4 py-3 text-sm font-bold hover:bg-surface-container transition-colors shadow-sm">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-5 h-5" alt="Google"> Google
                    </a>
                    <a  class="flex items-center justify-center gap-2 rounded-xl border border-outline-variant/60 bg-white px-4 py-3 text-sm font-bold hover:bg-surface-container transition-colors shadow-sm">
                        <img src="https://www.svgrepo.com/show/475647/facebook-color.svg" class="w-5 h-5" alt="Facebook"> Facebook
                    </a>
                </div>
            </form>
            <footer class="mt-8 text-center">
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Zaten bir hesabınız var mı?
                    <a class="font-label-lg text-label-lg text-secondary font-bold hover:text-primary transition-colors underline decoration-dashed decoration-outline-variant hover:decoration-primary ml-1" href="/User/Login">
                        Giriş Yap
                    </a>
                </p>
            </footer>
        </main>
    </div>
</body>
</html>

            <style>

    /* --- ASP.NET Akıllı Hata Yönetimi --- */
    /* Hata yoksa kutuyu tamamen gizler (If kullanmaya gerek kalmaz) */
    .validation-summary-valid {
        display: none !important;
    }

    /* Hata varsa kutuyu gösterir ve hafifçe sarsar */
    .validation-summary-errors {
        display: block;
        animation: errorShake 0.4s ease-in-out;
    }

        /* ASP.NET'in ürettiği UL (Liste) yapısını özelleştirme */
        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 0.5rem; /* Hatalar arası boşluk */
        }

            /* Her bir hata satırının tasarımı */
            .validation-summary-errors ul li {
                display: flex;
                align-items: flex-start;
                font-size: 0.875rem; /* 14px */
                font-weight: 500;
                color: var(--color-on-error-container, #93000a);
                line-height: 1.4;
            }

                /* Her hatanın başına şık bir ikon ekleme */
                .validation-summary-errors ul li::before {
                    content: "chevron_right";
                    font-family: "Material Symbols Outlined";
                    font-size: 1.125rem;
                    margin-right: 0.375rem;
                    color: var(--color-error, #ba1a1a);
                    flex-shrink: 0;
                }

    /* Dikkat çekici sarsıntı efekti */
    @@keyframes errorShake {
        0%, 100%

    {
        transform: translateX(0);
    }

    25% {
        transform: translateX(-4px);
    }

    50% {
        transform: translateX(4px);
    }

    75% {
        transform: translateX(-4px);
    }

    }

            </style>