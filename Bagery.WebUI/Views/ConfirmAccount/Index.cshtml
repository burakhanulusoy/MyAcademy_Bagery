<body class="bg-background text-on-background font-body-lg min-h-screen flex flex-col md:flex-row relative">
    <div class="hidden md:block w-1/2 h-screen relative bg-surface-container-low overflow-hidden">
        <img alt="Kahve ve hamur işi yakından görünümü" class="w-full h-full object-cover absolute inset-0 mix-blend-multiply opacity-90" data-alt="Seramik bir kupada dumanı tüten koyu kahvenin ve rustik, açık renkli ahşap bir masa üzerinde duran çıtır, altın rengi bir kruvasanın son derece detaylı, makro fotoğrafı. Işıklandırma yumuşak, pencereden süzülen sabah ışığı sıcak, rahatlatıcı gölgeler yaratıyor. Genel atmosfer davetkar, sakin ve zanaatkar hissiyatı veriyor, keten ve ahşap gibi dokunsal dokulara odaklanan butik bir mahalle fırını estetiğiyle uyumlu." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDAhqre83OoWgOoSfuPnG-HjTBsXc9kPvLddMxO41S2MbksWulDW1ZcA8xP2Nlo1Y7y9lQo6MpHi_6IDGp6xjIRbMInFWoDd24r8H_NzBz_6ZOjU1O8_xC5qUddFknQSX3tFxa3XkaRmvaD5fRCcrXs4fBKGXpzKqXaw4_zpU-XlpOJvWYJ2Tvwpj3r-WKvtNUZRjG5qgSazDOePyH37jz0JrLc7ZSOTDTHOO-vzlgSZUctsha7CRn743iO61hD108lXBd1V_TjQ01u" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent"></div>
        <div class="absolute bottom-12 left-12 max-w-sm">
            <div class="font-display text-display text-surface-container-lowest mb-4">BAKERY</div>
            <p class="font-body-lg text-body-lg text-surface-container-lowest/90">Özenle hazırlanan ve sizi bekleyen taptaze lezzetler.</p>
        </div>
    </div>
    <div class="w-full md:w-1/2 h-screen flex items-center justify-center bg-surface relative noise-bg px-margin-mobile md:px-gutter">
        <div class="max-w-md w-full relative z-10 flex flex-col space-y-8">

            <div class="text-center md:text-left space-y-4">
                <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary tracking-tight">E-postanızı doğrulayın</h1>
                <p class="font-body-md text-body-md text-on-surface-variant">
                    <span class="font-bold text-primary">@ViewBag.Email</span> adresine 6 haneli yeni bir kod gönderdik. <br />
                    Hesabınızı onaylamak için lütfen kodu aşağıya girin.
                </p>
            </div>

            <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50" role="alert">
                @Html.ValidationSummary()
            </div>


            <form method="post" id="verificationForm" class="space-y-8">
                <input type="hidden" name="Email" value="@ViewBag.Email" />

                <input type="hidden" name="Code" id="fullCode" />

                <div class="flex justify-between gap-2 md:gap-4" role="group">
                    <input class="otp-input w-12 h-14 md:w-14 md:h-16 text-center font-headline-lg text-primary bg-surface-container-lowest border-2 border-outline-variant rounded focus:border-primary focus:ring-0 focus:outline-none" maxlength="1" type="text" />
                    <input class="otp-input w-12 h-14 md:w-14 md:h-16 text-center font-headline-lg text-primary bg-surface-container-lowest border-2 border-outline-variant rounded focus:border-primary focus:ring-0 focus:outline-none" maxlength="1" type="text" />
                    <input class="otp-input w-12 h-14 md:w-14 md:h-16 text-center font-headline-lg text-primary bg-surface-container-lowest border-2 border-outline-variant rounded focus:border-primary focus:ring-0 focus:outline-none" maxlength="1" type="text" />
                    <input class="otp-input w-12 h-14 md:w-14 md:h-16 text-center font-headline-lg text-primary bg-surface-container-lowest border-2 border-outline-variant rounded focus:border-primary focus:ring-0 focus:outline-none" maxlength="1" type="text" />
                    <input class="otp-input w-12 h-14 md:w-14 md:h-16 text-center font-headline-lg text-primary bg-surface-container-lowest border-2 border-outline-variant rounded focus:border-primary focus:ring-0 focus:outline-none" maxlength="1" type="text" />
                    <input class="otp-input w-12 h-14 md:w-14 md:h-16 text-center font-headline-lg text-primary bg-surface-container-lowest border-2 border-outline-variant rounded focus:border-primary focus:ring-0 focus:outline-none" maxlength="1" type="text" />
                </div>

                <button type="submit" onclick="submitForm()" class="w-full py-4 bg-primary text-on-primary font-label-lg text-label-lg rounded hover:bg-primary/90 transition-all flex items-center justify-center gap-2">
                    E-postayı Doğrula
                    <span class="material-symbols-outlined" style="font-size: 20px;">arrow_forward</span>
                </button>
            </form>
        </div>
    </div>
</body>



</html>


<script>
    // Form gönderilirken 6 kutudaki değeri alıp tek bir string (örn: "123456") yapar
    function submitForm() {
        let code = "";
        const inputs = document.querySelectorAll('.otp-input');
        inputs.forEach(input => {
            code += input.value;
        });
        document.getElementById('fullCode').value = code;
    }

    // Kutular arası otomatik geçiş için ekstra UX güzelliği
    const otpInputs = document.querySelectorAll('.otp-input');
    otpInputs.forEach((input, index) => {
        input.addEventListener('input', (e) => {
            if(e.target.value.length === 1 && index < otpInputs.length - 1) {
                otpInputs[index + 1].focus();
            }
        });
        input.addEventListener('keydown', (e) => {
            if(e.key === 'Backspace' && !e.target.value && index > 0) {
                otpInputs[index - 1].focus();
            }
        });
    });
</script>