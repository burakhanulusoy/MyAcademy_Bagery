@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = null;
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,200..900;1,7..72,200..900&amp;family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "primary": "#442a22",
                      "primary-container": "#5d4037",
                      "on-primary": "#ffffff",
                      "secondary-container": "#fed4c8",
                      "on-secondary-container": "#795950",
                      "background": "#faf9f6",
                      "on-background": "#1a1c1a",
                      "surface": "#faf9f6",
                      "on-surface": "#1a1c1a",
                      "on-surface-variant": "#504441",
                      "outline": "#827470",
                      "outline-variant": "#d4c3be",
                      "error": "#ba1a1a",
                      "error-container": "#ffdad6",
                      "surface-container-lowest": "#ffffff"
              },
              "spacing": {
                      "section-gap": "80px",
                      "margin-mobile": "16px",
                      "gutter": "24px",
                      "base": "8px"
              },
              "fontFamily": {
                      "display": ["Literata"],
                      "headline-lg": ["Literata"],
                      "body-md": ["Plus Jakarta Sans"],
                      "label-lg": ["Plus Jakarta Sans"],
                      "form-input": ["Plus Jakarta Sans"]
              }
            },
          },
        }
    </script>
    <style>
        .linen-texture {
            background-color: #faf9f6;
            background-image: radial-gradient(#d4c3be 0.5px, transparent 0.5px);
            background-size: 24px 24px;
        }

        .artisan-shadow {
            box-shadow: 0 10px 40px -10px rgba(75, 54, 33, 0.15);
        }

        .inner-glow {
            box-shadow: inset 0 1px 0 0 rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen overflow-x-hidden">
    <main class="flex min-h-screen">
        <!-- Sol Görsel Panel -->
        <section class="hidden lg:block lg:w-1/2 relative overflow-hidden">
            <div class="absolute inset-0 bg-primary/20 mix-blend-multiply z-10"></div>
            <img class="absolute inset-0 w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB6sITH1AlgOZk1qmwuyYKy10LzTKDACBLuilvbnK0coDx_c5pI56SYejCuLgqDCoAqSHQ0Xn_9zeMmBwCVCdnGMvtgHSp54322vlDZxNuhn5XjVFOgNUTalVcKqSoe2gITK4IsRppZwTBv89ElQLK7J5NbWfJDTKoBGEj1Hed6pUSIIRIZnPA_7vxFAiiATOF5KeVL6TNhl4MFezaofWGggtn1Z_7SpAlKlIcSyBNF41CHXbPTCgqYMP7ZtAwtbLUHX_ZshavudkU5" alt="Bakery" />
            <div class="absolute inset-0 flex flex-col justify-center items-center z-20 p-gutter text-center">
                <div class="bg-surface-container-lowest/80 backdrop-blur-md p-12 artisan-shadow rounded-xl max-w-md border border-outline-variant/30">
                    <span class="font-display text-4xl text-primary tracking-tight block mb-4">BAKERY</span>
                    <div class="w-12 h-px bg-primary mx-auto mb-6"></div>
                    <p class="font-body-lg text-on-surface-variant leading-relaxed text-lg">Artizanal lezzetlerin merkezinde, her detayda özen ve sevgi var.</p>
                </div>
            </div>
        </section>

        <!-- Sağ Form Panel -->
        <section class="w-full lg:w-1/2 flex items-center justify-center linen-texture p-6">
            <div class="w-full max-w-[440px]">
                <a class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors mb-12 group" href="/">
                    <span class="material-symbols-outlined group-hover:-translate-x-1 transition-transform">arrow_back</span>
                    <span class="font-label-lg uppercase tracking-widest text-xs">Geri Dön</span>
                </a>

                <header class="mb-8">
                    <h1 class="font-display text-3xl md:text-4xl text-primary mb-4">Şifrenizi Sıfırlayın</h1>
                    <p class="text-on-surface-variant">Şifre sıfırlama linki için kayıtlı e-posta adresinizi girin.</p>
                </header>

                <!-- Başarı Mesajı (TempData) -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mb-6 p-4 bg-secondary-container text-on-secondary-container rounded-lg artisan-shadow flex items-center gap-3 border border-outline-variant/20 animate-in fade-in slide-in-from-top-4 duration-500">
                        <span class="material-symbols-outlined">mail</span>
                        <span class="font-label-lg font-semibold">@TempData["SuccessMessage"]</span>
                    </div>
                }

                <!-- Hata Özeti (Validation Summary) -->
                <div asp-validation-summary="All" class="mb-6 p-4 bg-error-container text-error rounded-lg text-sm artisan-shadow" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="space-y-6">
                    <div class="space-y-2">
                        <label class="font-label-lg text-on-surface block px-1" for="email">E-posta Adresi</label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-outline group-focus-within:text-primary transition-colors">
                                <span class="material-symbols-outlined">mail</span>
                            </div>
                            <input class="w-full pl-12 pr-4 py-4 bg-surface-container-lowest border-2 border-outline-variant focus:border-primary focus:ring-0 rounded-lg font-form-input text-on-surface transition-all artisan-shadow"
                                   id="email" name="email" type="email" placeholder="ornek@email.com" value="@ViewBag.Email" required />
                        </div>
                    </div>

                    <button class="w-full py-4 bg-primary text-on-primary font-label-lg rounded-lg artisan-shadow inner-glow hover:bg-primary-container active:scale-[0.98] transition-all flex justify-center items-center gap-3" type="submit">
                        <span>Bağlantı Gönder</span>
                        <span class="material-symbols-outlined text-xl">send</span>
                    </button>
                </form>

                <footer class="mt-12 opacity-60 flex justify-center lg:justify-start">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary">bakery_dining</span>
                        <span class="font-display text-primary font-bold">BAKERY</span>
                    </div>
                </footer>
            </div>
        </section>
    </main>
</body>
</html>