@model Bagery.WebUI.MediatorPattern.Commands.UserCommands.ResetPasswordCommand
@{
    ViewData["Title"] = "Yeni Şifre Belirleyin";
    Layout = null;
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Literata:wght@600;700&family=Plus+Jakarta+Sans:wght@400;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
          theme: {
            extend: {
              colors: {
                "primary": "#442a22",
                "background": "#faf9f6",
                "surface-container-lowest": "#ffffff",
                "outline-variant": "#d4c3be",
                "error": "#ba1a1a",
                "error-container": "#ffdad6"
              }
            }
          }
        }
    </script>
    <style>
        .linen-texture {
            background-color: #faf9f6;
            background-image: radial-gradient(#d4c3be 0.5px, transparent 0.5px);
            background-size: 24px 24px;
        }

        .artisan-shadow {
            box-shadow: 0 10px 40px -10px rgba(75, 54, 33, 0.15);
        }
    </style>
</head>
<body class="bg-background font-body-md min-h-screen">
    <main class="flex min-h-screen">
        <section class="hidden lg:block lg:w-1/2 relative overflow-hidden">
            <img class="absolute inset-0 w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB6sITH1AlgOZk1qmwuyYKy10LzTKDACBLuilvbnK0coDx_c5pI56SYejCuLgqDCoAqSHQ0Xn_9zeMmBwCVCdnGMvtgHSp54322vlDZxNuhn5XjVFOgNUTalVcKqSoe2gITK4IsRppZwTBv89ElQLK7J5NbWfJDTKoBGEj1Hed6pUSIIRIZnPA_7vxFAiiATOF5KeVL6TNhl4MFezaofWGggtn1Z_7SpAlKlIcSyBNF41CHXbPTCgqYMP7ZtAwtbLUHX_ZshavudkU5" alt="Bakery" />
            <div class="absolute inset-0 bg-primary/20 z-10"></div>
        </section>

        <section class="w-full lg:w-1/2 flex items-center justify-center linen-texture p-6">
            <div class="w-full max-w-[440px]">
                <header class="mb-8">
                    <h1 class="font-display text-3xl text-primary mb-2 text-center md:text-left">Yeni Şifre Belirleyin</h1>
                    <p class="text-on-surface-variant text-center md:text-left">Güvenliğiniz için lütfen güçlü bir şifre seçin.</p>
                </header>

                <div asp-validation-summary="All" class="mb-6 p-4 bg-error-container text-error rounded-lg text-sm artisan-shadow border border-error/10"></div>

                <form asp-controller="Account" asp-action="ResetPassword" method="post" class="space-y-5">

                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Token" />

                    <div asp-validation-summary="All" class="text-error text-sm mb-4"></div>

                    <div class="space-y-2">
                        <label class="text-sm font-semibold px-1">Yeni Şifre</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-4 text-gray-400">lock</span>
                            <input asp-for="NewPassword" type="password" class="w-full pl-12 pr-4 py-4 bg-white border-2 border-outline-variant focus:border-primary rounded-lg artisan-shadow" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-semibold px-1">Şifre Tekrar</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-4 text-gray-400">lock_reset</span>
                            <input asp-for="ConfirmPassword" type="password" class="w-full pl-12 pr-4 py-4 bg-white border-2 border-outline-variant focus:border-primary rounded-lg artisan-shadow" placeholder="••••••••" required />
                        </div>
                    </div>

                    <button type="submit" class="w-full py-4 bg-primary text-white font-bold rounded-lg artisan-shadow hover:opacity-90 transition-all flex justify-center items-center gap-2">
                        <span>Şifreyi Güncelle</span>
                        <span class="material-symbols-outlined">key</span>
                    </button>
                </form>
            </div>
        </section>
    </main>
</body>
</html>