@model List<GetProductsQueryResult>
@*
    get last 10
    For more information on enabling MVC for empty projects, visit http://go.microsoft.com/fwlink/?LinkID=397860
*@

<div class="product-grid">
    <div class="similar-products owl-carousel owl-theme">
        @foreach (var item in Model)
        {
            <div class="item">
                <div class="card product-card h-100 shadow-sm">
                    <a href="javascript:;" class="position-absolute end-0 top-0 m-3">
                        <div class="product-wishlist">
                            <i class="bx bx-heart"></i>
                        </div>
                    </a>

                    <img src="@item.MainImageUrl" class="card-img-top" alt="@item.ProductName">

                    <div class="card-body">
                        <div class="product-info">
                            <a href="javascript:;">
                                <p class="product-catergory font-13 mb-1 text-muted">@item.Category.CategoryName</p>
                            </a>
                            <a href="/Admin/Product/ProductDetail/@item.Id">
                                <h6 class="product-name mb-2 text-truncate">@item.ProductName</h6>
                            </a>
                            <div class="d-flex align-items-center mb-3">
                                <div class="product-price">
                                    <span class="fs-5 fw-bold">$@item.Price</span>
                                </div>
                                <div class="cursor-pointer ms-auto text-warning">
                                    <i class="bx bxs-star"></i>
                                    <span>5.0</span>
                                </div>
                            </div>
                            <div class="product-action">
                                <div class="d-grid">
                                    <a href="/Admin/Product/ProductDetail/@item.Id" class="btn btn-primary btn-ecomm">
                                        <i class='bx bx-search-alt'></i> Ürünü İncele
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>






                            <style>

    /* Slider içindeki kart resimlerini sabitleme */
    .similar-products .product-card .card-img-top {
        width: 100%;
        height: 180px; /* Slider için 180px idealdir, ihtiyaca göre 200px yapabilirsin */
        object-fit: cover; /* Resmi sünnetmeden kutuya sığdırır */
        border-bottom: 1px solid #f0f0f0; /* Resim ile yazı arasına hafif bir çizgi */
    }

    /* Kartların içindeki yazı alanlarını hizalama */
    .similar-products .product-card {
        transition: transform 0.3s ease;
        border: 1px solid #eee;
    }

        .similar-products .product-card:hover {
            transform: translateY(-5px); /* Üzerine gelince hafif yükselme efekti */
        }

                            </style>