@model ChangePasswordCommand
@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    body, * {
        font-family: 'Montserrat', sans-serif !important;
    }

    .modern-card-container {
        padding-top: 50px;
        padding-bottom: 50px;
    }

    .modern-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        max-width: 500px; /* Kart genişliğini sınırla */
        margin: 0 auto; /* Merkezle */
        overflow: hidden;
        background-color: #fff;
    }

    .custom-card-header {
        background-color: #9C27B0; /* Mor */
        color: white;
        border: none;
        padding: 25px 20px;
        border-radius: 12px 12px 0 0;
    }

        .custom-card-header h4 {
            margin: 0;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

    .modern-card-body {
        padding: 35px;
    }

    .modern-input {
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        padding: 12px 15px;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

        .modern-input:focus {
            border-color: #CE93D8;
            box-shadow: 0 0 0 0.2rem rgba(206, 147, 216, 0.25);
        }

    .form-floating label {
        color: #757575;
        padding-left: 20px;
    }

    .form-floating input:focus ~ label,
    .form-floating input:not(:placeholder-shown) ~ label {
        color: #9C27B0; /* Mor */
    }

    .modern-validation-summary {
        border: none;
        border-radius: 8px;
        margin-bottom: 25px;
    }

        .modern-validation-summary ul {
            margin: 0;
            padding-left: 15px;
        }

    .custom-btn-primary {
        background-color: #9C27B0;
        border: none;
        border-radius: 25px;
        color: white;
        padding: 12px 30px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }

        .custom-btn-primary:hover {
            background-color: #7B1FA2;
            transform: translateY(-2px);
        }

    .custom-btn-outline {
        border: 2px solid #E1BEE7;
        color: #9C27B0;
        border-radius: 25px;
        background-color: transparent;
        padding: 10px 25px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: border-color 0.3s ease, color 0.3s ease, background-color 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .custom-btn-outline:hover {
            border-color: #9C27B0;
            background-color: rgba(225, 190, 231, 0.2);
            color: #7B1FA2;
        }
</style>

<br />
<br />
<br />
<br />


<div class="container modern-card-container">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="modern-card">
                <div class="custom-card-header text-center">
                    <h4>
                        <i class="fas fa-key me-2"></i> Şifrenizi Değiştirin
                    </h4>
                </div>
                <div class="modern-card-body">
                    <br />
                    <div asp-validation-summary="All" class="alert alert-danger modern-validation-summary text-danger" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")">
                        <strong>Lütfen aşağıdaki hataları düzeltin:</strong>
                    </div>

                    <form asp-action="ChangePassword" method="post">

                        <div class="form-floating mb-3">
                            <input asp-for="NowPassword" type="password" class="form-control modern-input" id="nowPassword" placeholder="Mevcut Şifre" />
                            <label asp-for="NowPassword">Mevcut Şifre</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="NewPassword" type="password" class="form-control modern-input" id="newPassword" placeholder="Yeni Şifre" />
                            <label asp-for="NewPassword">Yeni Şifre</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="NewConfirmPassword" type="password" class="form-control modern-input" id="newConfirmPassword" placeholder="Yeni Şifre (Tekrar)" />
                            <label asp-for="NewConfirmPassword">Yeni Şifre (Tekrar)</label>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="custom-btn-primary btn-lg">
                                Şifreyi Güncelle
                            </button>
                            <a asp-controller="User" asp-action="UpdateUser" class="custom-btn-outline text-center justify-content-center">
                                <i class="fas fa-arrow-left me-2"></i> İptal Et ve Geri Dön
                            </a>
                        </div>

                    </form>
                   
                </div>
            </div>
        </div>
    </div>
</div>
<br />
<br />
<br />
<br />
<br />
<br />
<br />
