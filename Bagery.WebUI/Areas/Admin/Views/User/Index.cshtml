@model PagedList<GetUsersQueryResult>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var customOption = PagedListRenderOptions.Bootstrap4PageNumbersPlusPrevAndNext;
    customOption.LinkToPreviousPageFormat = "« Önceki";
    customOption.LinkToNextPageFormat = "Sonraki »";
}

<div class="page-content-wrapper">
    <div class="page-content">

        <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
            <div class="breadcrumb-title pe-3">Sisteme Kayıtlı Kullanıcılar</div>
            <div class="ps-3">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 p-0 align-items-center">
                        <li class="breadcrumb-item">
                            <a href="javascript:;"><ion-icon name="home-outline"></ion-icon></a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Üyelerimiz</li>
                    </ol>
                </nav>
            </div>
        </div>

        <!-- Arama Kutusu -->
        <div class="row mb-4">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="input-group">
                    <span class="input-group-text bg-transparent"><ion-icon name="search-outline"></ion-icon></span>
                    <input type="text" id="globalSearchInput" class="form-control border-start-0"
                           placeholder="Kullanıcı adı veya mail ile ara..."
                           value="@ViewData["CurrentSearch"]">
                </div>
            </div>
        </div>

        <div class="row">
            @if (Model.Any())
            {
                @foreach (var user in Model)
                {
                    <div class="col-12 mb-4">
                        <div class="card overflow-hidden radius-10">
                            <div class="profile-cover bg-dark position-relative mb-4">
                                <div class="user-profile-avatar shadow position-absolute top-50 start-0 translate-middle-x">
                                    <img src="@(user.ImageUrl ?? "https://images.unsplash.com/photo-1681398836231-d0b89bd571d6?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.1.0")" alt="User Avatar">
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="mt-5 d-flex align-items-start justify-content-between">
                                    <div class="">
                                        <h3 class="mb-2">@user.FullName</h3>
                                        <p class="mb-1 text-muted">@(user.Job ?? "Belirtilmemiş")</p>
                                        <p class="mb-2">@(user.Address ?? "Belirtilmemiş")</p>

                                        <div class="">

                                            @if (!string.IsNullOrWhiteSpace(user.Email))
                                            {
                                                <a href="mailto:@user.Email" class="badge rounded-pill bg-primary" title="Mail Gönder">@user.Email</a>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-secondary">Belirtilmemiş</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="">
                                        <a href="/Admin/User/GetUserById/@user.Id" class="btn btn-primary">
                                            <ion-icon name="send-sharp" class="me-1"></ion-icon>Profili İncele
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Arama sonucu boş dönerse gösterilecek mesaj -->
                <div class="col-12 text-center mt-4">
                    <p class="text-muted">Arama kriterlerinize uygun kullanıcı bulunamadı.</p>
                </div>
            }
        </div>

        <div class="d-flex justify-content-center mt-3">
            <!-- asp-route-search parametresi eklendi. Böylece arama yaptıktan sonra 2. sayfaya geçince arama sıfırlanmaz. -->
            <pager asp-action="Index" asp-controller="User" asp-area="Admin" list="@Model" options="@customOption" asp-route-search="@ViewData["CurrentSearch"]"></pager>
        </div>

    </div>
</div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let typingTimer;
            const doneTypingInterval = 500; // Kullanıcı yazmayı bıraktıktan yarım saniye sonra arar
            const searchInput = document.getElementById("globalSearchInput");

            // Kullanıcı klavyeden elini çektiğinde sayacı başlat
            searchInput.addEventListener('keyup', function () {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(performSearch, doneTypingInterval);
            });

            // Kullanıcı yazmaya devam ediyorsa sayacı iptal et
            searchInput.addEventListener('keydown', function () {
                clearTimeout(typingTimer);
            });

            function performSearch() {
                const searchTerm = searchInput.value.trim();
                const currentSearch = '@Html.Raw(ViewData["CurrentSearch"] ?? "")';

                // Eğer kutudaki yazı, zaten yapılmış arama ile aynıysa sayfayı boşuna yenileme
                if (searchTerm !== currentSearch) {
                    // Sayfayı yeni arama parametresiyle Controller'a yönlendir (Admin area içinde olduğun için url yolu önemli)
                    window.location.href = '@Url.Action("Index", "User", new { area = "Admin" })?search=' + encodeURIComponent(searchTerm);
                }
            }

            // İmleci arama kutusunun sonuna konumlandır (kullanıcı deneyimi için)
            if (searchInput.value.length > 0) {
                searchInput.focus();
                var val = searchInput.value;
                searchInput.value = '';
                searchInput.value = val;
            }
        });
    </script>
