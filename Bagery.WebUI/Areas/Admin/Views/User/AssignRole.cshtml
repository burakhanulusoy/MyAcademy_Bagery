@model AssignRoleUserCommand
@{
    ViewData["Title"] = "AssignRole";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<form method="post">
    
    @for (int i = 0; i < Model.Roles.Count; i++)
    {

        <div class="form-check">

            <input type="hidden" asp-for="@Model.Roles[i].RoleName" />
            <input type="hidden" asp-for="@Model.Roles[i].RoleId" />
            <input type="hidden" asp-for="@Model.Id" />
            
            <input type="checkbox" asp-for="@Model.Roles[i].RoleExist" class="form-check-input" />
            <label class="form-check-label">@Model.Roles[i].RoleName</label>


        </div>

    }

    <button class="btn btn-success">Rol Ata</button>

</form>



