@model UpdateContactSocialMediaCommand
@{
    ViewData["Title"] = "UpdateContactSocialMedia";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="page-content-wrapper">
    <div class="page-content">

        <div class="card shadow-sm border-0 radius-10 w-50 mx-auto mt-4">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 text-center">
                <h5 class="mb-0 text-primary fw-bold"><i class="bx bx-edit"></i> Sosyal Medya Hesabını Güncelle</h5>
                <p class="text-muted small mt-1">Mevcut sosyal medya bilgileri üzerinde değişiklik yapıyorsunuz.</p>
            </div>

            <div class="card-body p-4">
                <form enctype="multipart/form-data" method="post" id="updateItemForm" asp-action="UpdateContactSocialMedia" asp-controller="ContactSocialMedia">

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="IconUrl" />
                    <input type="hidden" asp-for="ContactId" /> <div class="mb-3">


                        <label class="form-label fw-semibold">Sosyal Medya Adı</label>
                        <input class="form-control" type="text" placeholder="Örn: Instagram, LinkedIn, X..." asp-for="SocialMediaName"  />
                        <span class="badge bg-danger text-wrap text-start mt-1" asp-validation-for="SocialMediaName"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bağlantı (URL)</label>
                        <input class="form-control" type="url" placeholder="https://..." asp-for="SocialMediaUrl"  />
                        <span class="badge bg-danger text-wrap text-start mt-1" asp-validation-for="SocialMediaUrl"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Platform İkonu (Opsiyonel)</label>
                        <input class="form-control" type="file" asp-for="File" />
                        <span class="badge bg-danger text-wrap text-start mt-1" asp-validation-for="File"></span>

                        <div class="d-flex align-items-center gap-2 mt-2">
                            <img src="@Model.IconUrl" alt="Mevcut İkon" width="30" height="30" class="rounded shadow-sm" onerror="this.style.display='none'" />
                            <small class="text-muted"><i class="bx bx-info-circle"></i> Sadece ikonu değiştirmek istiyorsanız yeni bir dosya yükleyin.</small>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-end gap-3">
                        <a href="/Admin/Contact/Index" class="btn btn-outline-secondary px-4 d-flex align-items-center gap-1">
                            <i class="bx bx-x fs-5"></i> İptal
                        </a>
                        <button type="button" onclick="confirmUpdate()" class="btn btn-primary px-5 d-flex align-items-center gap-1 shadow-sm">
                            <i class="bx bx-save fs-5"></i> Değişiklikleri Kaydet
                        </button>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function confirmUpdate() {
        var form = document.getElementById("updateItemForm");

        if (form.checkValidity()) {
            Swal.fire({
                title: "Güncellemek istediğinize emin misiniz?",
                text: "Yaptığınız değişiklikler sisteme kaydedilecektir.",
                icon: "question",
                showCancelButton: true,
                confirmButtonColor: "#0d6efd", // Güncelleme işlemi için Primary mavi renk
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Evet, Güncelle!",
                cancelButtonText: "İptal"
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        } else {
            form.reportValidity();
        }
    }
</script>
