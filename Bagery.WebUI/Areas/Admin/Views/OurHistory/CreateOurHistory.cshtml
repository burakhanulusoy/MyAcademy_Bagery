@model CreateOurHistoryCommand
@{
    ViewData["Title"] = "CreateOurHistory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="page-content-wrapper">
    <div class="page-content">

        <div class="card shadow-sm border-0 radius-10">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                <h5 class="mb-0 text-primary fw-bold"><i class="bx bx-book-open"></i> Yeni Hikaye (Hakkımızda) Ekle</h5>
            </div>

            <div class="card-body p-4">
                <form enctype="multipart/form-data" method="post" id="createItemForm">

                    <div class="row">
                        <div class="col-md-6 border-end pe-md-4">

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Başlık</label>
                                <input class="form-control" type="text" placeholder="Örn: Hikayemiz Nasıl Başladı?" asp-for="Title"  />
                                <span class="badge bg-danger text-wrap text-start mt-1 p-2" asp-validation-for="Title"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Hikaye İçeriği (Açıklama)</label>
                                <textarea class="form-control" placeholder="Kurumun hikayesini detaylıca yazınız..." asp-for="Description" rows="8" ></textarea>
                                <span class="badge bg-danger text-wrap text-start mt-1 p-2" asp-validation-for="Description"></span>
                            </div>

                        </div>

                        <div class="col-md-6 ps-md-4">

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Ana Görsel </label>
                                <input class="form-control" type="file" asp-for="MainFile"  />
                                <span class="badge bg-danger text-wrap text-start mt-1 p-2" asp-validation-for="MainFile"></span>
                                <small class="text-muted d-block mt-1"><i class="bx bx-info-circle"></i> Sahnede en büyük görünecek ana fotoğrafı seçin.</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">İkincil Görsel</label>
                                <input class="form-control" type="file" asp-for="File"  />
                                <span class="badge bg-danger text-wrap text-start mt-1 p-2" asp-validation-for="File"></span>
                                <small class="text-muted d-block mt-1"><i class="bx bx-info-circle"></i> Metnin yanında duracak destekleyici fotoğrafı seçin.</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">İmza Görseli </label>
                                <input class="form-control" type="file" asp-for="SignatureFile"  />
                                <span class="badge bg-danger text-wrap text-start mt-1 p-2" asp-validation-for="SignatureFile"></span>
                                <small class="text-muted d-block mt-1"><i class="bx bx-info-circle"></i> Şeffaf arka planlı (PNG) bir kurucu imza görseli seçin.</small>
                            </div>

                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-end gap-3">
                        <a href="/Admin/OurHistory/Index" class="btn btn-outline-secondary px-4 d-flex align-items-center gap-1">
                            <i class="fadeIn animated bx bx-x fs-5"></i> İptal
                        </a>
                        <button type="button" onclick="confirmCreate()" class="btn btn-primary px-5 d-flex align-items-center gap-1 shadow-sm">
                            <i class="fadeIn animated bx bx-save fs-5"></i> Kaydet
                        </button>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function confirmCreate() {
        // Formu DOM üzerinden seçiyoruz
        var form = document.getElementById("createItemForm");

        // Tarayıcının yerleşik validasyonunu kullanıyoruz (Kütüphane gerektirmez)
        if (form.checkValidity()) {
            Swal.fire({
                title: "Kaydetmek istediğinize emin misiniz?",
                text: "Yeni hikaye veritabanına eklenecektir.",
                icon: "question",
                showCancelButton: true,
                confirmButtonColor: "#0d6efd", // Primary mavi renk ile uyumlu
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Evet, Ekle!",
                cancelButtonText: "İptal"
            }).then((result) => {
                if (result.isConfirmed) {
                    // Kullanıcı onay verirse formu gönder
                    form.submit();
                }
            });
        } else {
            // Formda boş alan varsa tarayıcının varsayılan hata balonlarını göster
            form.reportValidity();
        }
    }
</script>
