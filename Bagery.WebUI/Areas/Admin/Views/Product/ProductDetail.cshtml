                                    <div class="col-12 col-lg-5">
                                        <div class="image-zoom-section">
                                            <div class="product-gallery owl-carousel owl-theme border rounded mb-3 p-3" data-slider-id="1">
                                                <div class="item">
                                                    <img src="@Model.MainImageUrl" class="img-fluid" alt="">
                                                </div>
                                                <div class="item">
                                                    <img src="@Model.ImageUrl1" class="img-fluid" alt="">
                                                </div>
                                                <div class="item">
                                                    <img src="@Model.ImageUrl2" class="img-fluid" alt="">
                                                </div>
                                                
                                            </div>
                                            <div class="owl-thumbs d-flex justify-content-center" data-slider-id="1">
                                                <button class="owl-thumb-item">
                                                    <img src="@Model.MainImageUrl" class="" alt="">
                                                </button>
                                                <button class="owl-thumb-item">
                                                    <img src="@Model.ImageUrl1" class="" alt="">
                                                </button>
                                                <button class="owl-thumb-item">
                                                    <img src="@Model.ImageUrl2" class="" alt="">
                                                </button>
                                                
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-lg-7">
                                        <div class="product-info-section p-3">
                                            <h3 class="mt-3 mt-lg-0 mb-0">@Model.ProductName</h3>
                                            <div class="product-rating d-flex align-items-center mt-2">
                                                <div class="rates cursor-pointer font-13">
                                                    <i class="bx bxs-star text-warning"></i>
                                                    <i class="bx bxs-star text-warning"></i>
                                                    <i class="bx bxs-star text-warning"></i>
                                                    <i class="bx bxs-star text-warning"></i>
                                                    <i class="bx bxs-star text-light-4"></i>
                                                </div>
                                                <div class="ms-1">
                                                    <p class="mb-0">(24 Ratings)</p>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center mt-3 gap-2">
                                                <h4 class="mb-0">$@Model.Price</h4>
                                            </div>
                                            <div class="mt-3">
                                                <h6>Discription :</h6>
                                                <p class="mb-0">@Model.Description</p>
                                            </div>
                                            <dl class="row mt-3">
                                                <dt class="col-sm-3">Urün ID</dt>
                                                <dd class="col-sm-9">#@Model.Id</dd>
                                                <dt class="col-sm-3">Varyanları</dt>

                                                @foreach(var item in Model.ProductVariants)
                                                {
                                                    if(item.IsAvailable)
                                                    {
                                                        <dd class="col-sm-9">@item.OptionName</dd>
                                                    }

                                                }

                                            </dl>
